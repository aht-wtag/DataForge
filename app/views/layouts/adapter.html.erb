<% content_for :content do %>
  <% if @adapter.present? %>
    <div class="space-y-6">
      <div class="border-b border-gray-200 pb-4">
        <div class="flex items-center justify-between">
          <div>
            <nav class="flex" aria-label="Breadcrumb">
              <ol class="flex items-center space-x-2 text-sm">
                <li>
                  <%= link_to "Adapters", adapters_path, class: "text-gray-500 hover:text-gray-700" %>
                </li>
                <li>
                  <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/>
                  </svg>
                </li>
                <li>
                  <span class="text-gray-900 font-medium"><%= @adapter.name %></span>
                </li>
              </ol>
            </nav>
          </div>
          <div class="flex items-center space-x-2">
            <%= render "shared/status_badge", status: @adapter.status %>
          </div>
        </div>
      </div>

      <div class="border-b border-gray-200">
        <nav class="-mb-px flex">
          <% nav_items = [
            { name: "Overview", path: adapter_path(@adapter) },
            { name: "Endpoints", path: adapter_endpoints_path(@adapter) },
            { name: "Credentials", path: adapter_credentials_path(@adapter) },
            { name: "Schedules", path: adapter_job_schedules_path(@adapter) }
          ] %>
          <% nav_items.each do |item| %>
            <% is_overview = item[:path] == adapter_path(@adapter) %>
            <% active = is_overview ? request.path == item[:path] : request.path.start_with?(item[:path]) %>
            <%= link_to item[:name], item[:path],
                  class: active ?
                    "border-blue-500 text-blue-600 whitespace-nowrap py-4 px-4 border-b-2 font-medium text-sm" :
                    "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 whitespace-nowrap py-4 px-4 border-b-2 font-medium text-sm" %>
          <% end %>
        </nav>
      </div>

      <%= yield %>
    </div>
  <% else %>
    <%= yield %>
  <% end %>
<% end %>

<%= render template: "layouts/application" %>
