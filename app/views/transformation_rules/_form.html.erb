<%= form_with(model: [adapter, endpoint, transformation_rule], local: true, class: "space-y-6") do |form| %>
  <% if transformation_rule.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <h2 class="text-sm font-medium text-red-800"><%= pluralize(transformation_rule.errors.count, "error") %> prohibited this rule from being saved:</h2>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% transformation_rule.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-y-8 gap-x-4 sm:grid-cols-6">
    <div class="sm:col-span-3">
      <%= form.label :source_path, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :source_path, placeholder: "data.items[0].name",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
      <p class="mt-1 text-xs text-gray-500">Dot-notation path to extract data from source JSON</p>
    </div>

    <div class="sm:col-span-3">
      <%= form.label :target_field, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :target_field, placeholder: "item_name",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :target_type, "Target Type", class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :target_type, TransformationRule.target_types.keys.map { |t| [t.humanize, t] }, {},
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :position, class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :position, min: 0,
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :default_value, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :default_value,
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-6">
      <%= form.label :transformation_expression, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :transformation_expression, rows: 3, placeholder: "Optional Ruby expression for transformation",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
    </div>

    <div class="sm:col-span-3">
      <div class="flex items-center">
        <%= form.check_box :enabled, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <%= form.label :enabled, class: "ml-2 block text-sm text-gray-900" %>
      </div>
    </div>
  </div>

  <div class="flex justify-end space-x-4 pt-6 mt-6 border-t border-gray-200">
    <%= link_to "Cancel", adapter_endpoint_transformation_rules_path(adapter, endpoint),
          class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
    <%= form.submit class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
