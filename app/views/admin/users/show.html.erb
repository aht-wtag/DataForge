<%= page_title "Admin - #{@user.full_name}" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @user.full_name %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= @user.email %></p>
    </div>
    <%= link_to "Back to Users", admin_users_path, class: "text-sm text-blue-600 hover:text-blue-900" %>
  </div>

  <div class="bg-white shadow overflow-hidden rounded-lg">
    <div class="px-6 py-5">
      <dl class="grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500">Role</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= role_badge(@user) %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Email</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.email %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Sign In Count</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.sign_in_count %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Current Sign In At</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.current_sign_in_at&.strftime("%B %d, %Y at %H:%M") || "Never" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Last Sign In At</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.last_sign_in_at&.strftime("%B %d, %Y at %H:%M") || "Never" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Created</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.created_at.strftime("%B %d, %Y") %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Adapters</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.adapters.count %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Locked</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.locked_at ? "Yes (since #{@user.locked_at.strftime("%B %d, %Y")})" : "No" %></dd>
        </div>
      </dl>
    </div>
  </div>

  <div>
    <h2 class="text-lg font-medium text-gray-900 mb-3">Change Role</h2>
    <div class="flex space-x-3">
      <% User.roles.each_key do |role| %>
        <% unless role == @user.role %>
          <%= button_to "Set as #{role.humanize}", update_role_admin_user_path(@user, role: role),
                method: :patch,
                class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
