<aside class="w-64 bg-white border-r border-gray-200 min-h-screen p-4">
  <nav class="space-y-1">
    <%= sidebar_link_to "Dashboard", root_path, icon: "home" %>

    <% if respond_to?(:adapters_path) %>
      <%= sidebar_link_to "Adapters", adapters_path, icon: "plug" %>
    <% end %>

    <% if respond_to?(:execution_logs_path) && policy(:execution_log).index? %>
      <%= sidebar_link_to "Execution Logs", execution_logs_path, icon: "document" %>
    <% end %>

    <% if respond_to?(:stored_data_index_path) && policy(:stored_datum).index? %>
      <%= sidebar_link_to "Stored Data", stored_data_index_path, icon: "database" %>
    <% end %>

    <% if current_user.admin? %>
      <div class="pt-4 mt-4 border-t border-gray-200">
        <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Admin</p>
        <% if respond_to?(:admin_users_path) %>
          <%= sidebar_link_to "Users", admin_users_path, icon: "users" %>
        <% end %>
        <% if respond_to?(:sidekiq_web_path) %>
          <%= sidebar_link_to "Sidekiq", sidekiq_web_path, icon: "activity" %>
        <% end %>
      </div>
    <% end %>

    <div class="pt-4 mt-4 border-t border-gray-200">
      <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Account</p>
      <%= sidebar_link_to "Edit Profile", edit_user_registration_path, icon: "user" %>
    </div>
  </nav>
</aside>
