<%= form_with(model: [adapter, job_schedule], local: true, class: "space-y-6") do |form| %>
  <% if job_schedule.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <h2 class="text-sm font-medium text-red-800"><%= pluralize(job_schedule.errors.count, "error") %> prohibited this schedule from being saved:</h2>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% job_schedule.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-y-8 gap-x-4 sm:grid-cols-6">
    <div class="sm:col-span-3">
      <%= form.label :endpoint_id, "Endpoint", class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :endpoint_id, adapter.endpoints, :id, :name, { prompt: "Select an endpoint" },
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-3">
      <%= form.label :cron_expression, "Cron Expression", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :cron_expression, placeholder: "*/5 * * * *",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
      <p class="mt-1 text-xs text-gray-500">Standard 5-field cron expression</p>
    </div>

    <div class="sm:col-span-3">
      <%= form.label :timezone, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :timezone, ActiveSupport::TimeZone.all.map { |tz| [tz.to_s, tz.tzinfo.name] }, {},
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-3">
      <div class="flex items-center mt-6">
        <%= form.check_box :enabled, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <%= form.label :enabled, class: "ml-2 block text-sm text-gray-900" %>
      </div>
    </div>
  </div>

  <div class="flex justify-end space-x-4 pt-6 mt-6 border-t border-gray-200">
    <%= link_to "Cancel", adapter_job_schedules_path(adapter),
          class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
    <%= form.submit class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
