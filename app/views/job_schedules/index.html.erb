<% page_title "Job Schedules — #{@adapter.name}" %>

<div class="space-y-6">
  <div class="sm:flex sm:items-center sm:justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Job Schedules</h1>
    <% if policy(JobSchedule).create? && @job_schedules.any? %>
      <%= link_to "New Schedule", new_adapter_job_schedule_path(@adapter),
            class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
    <% end %>
  </div>

  <% if @job_schedules.any? %>
    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Endpoint</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cron</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Human Readable</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Timezone</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Enabled</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Next Run</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Run</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @job_schedules.each do |schedule| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= link_to schedule.endpoint.name, adapter_job_schedule_path(@adapter, schedule), class: "hover:text-blue-600" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-mono">
                <%= schedule.cron_expression %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= humanize_cron(schedule.cron_expression) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= schedule.timezone %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if schedule.enabled? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Enabled</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Disabled</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if schedule.next_run_at %>
                  <%= schedule.next_run_at.strftime("%b %d, %H:%M") %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if schedule.last_run_at %>
                  <%= schedule.last_run_at.strftime("%b %d, %H:%M") %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <div class="flex justify-end space-x-2">
                  <%= link_to "Edit", edit_adapter_job_schedule_path(@adapter, schedule),
                        class: "text-blue-600 hover:text-blue-900" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @job_schedules.total_pages > 1 %>
      <div class="mt-4">
        <%= paginate @job_schedules %>
      </div>
    <% end %>
  <% else %>
    <%= render "shared/empty_state",
          title: "No schedules yet",
          description: "Create a schedule to run endpoints automatically on a cron basis.",
          button_text: "New Schedule",
          button_path: new_adapter_job_schedule_path(@adapter) %>
  <% end %>
</div>
