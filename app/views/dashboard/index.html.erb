<%= page_title "Dashboard" %>

<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="mt-1 text-sm text-gray-500">Welcome to DataForge, <%= current_user.first_name %>.</p>
  </div>

  <% if current_user.viewer? %>
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-blue-800">Read-Only Access</h3>
          <p class="mt-1 text-sm text-blue-700">You have viewer access. You can browse adapters and view execution logs, but cannot create or modify resources.</p>
        </div>
      </div>
    </div>
  <% elsif current_user.admin? %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-500 truncate">Adapters</p>
              <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @adapters_count %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-500 truncate">Users</p>
              <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @users_count %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-500 truncate">Execution Logs</p>
              <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @logs_count %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-500 truncate">Stored Records</p>
              <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @stored_data_count %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% elsif current_user.developer? %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-500 truncate">My Adapters</p>
              <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @my_adapters_count %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-500 truncate">My Execution Logs</p>
              <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @my_logs_count %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% unless current_user.viewer? %>
    <div>
      <h2 class="text-lg font-medium text-gray-900">Recent Execution Logs</h2>
      <% if @recent_logs.any? %>
        <div class="mt-3 bg-white shadow overflow-hidden rounded-lg">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Adapter</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Records</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Started</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @recent_logs.each do |log| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= log.adapter.name %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm"><%= render "shared/status_badge", status: log.status %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= log.records_extracted.to_i %> / <%= log.records_loaded.to_i %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= log.started_at ? log.started_at.strftime("%b %d, %H:%M") : "-" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="mt-3">
          <%= render "shared/empty_state", title: "No execution logs yet", description: "Execution logs will appear here once adapters are run." %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if current_user.admin? && @failed_logs&.any? %>
    <div>
      <h2 class="text-lg font-medium text-gray-900">Recent Failed Logs</h2>
      <div class="mt-3 bg-white shadow overflow-hidden rounded-lg">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Adapter</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Error</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @failed_logs.each do |log| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= log.adapter.name %></td>
                <td class="px-6 py-4 text-sm text-red-600"><%= log.error_message.present? ? truncate(log.error_message, length: 80) : "Unknown error" %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= log.created_at.strftime("%b %d, %H:%M") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
