<%= page_title "Dashboard" %>

<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="mt-1 text-sm text-gray-500">Welcome to DataForge, <%= current_user.first_name %>.</p>
  </div>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-500 truncate">Adapters</p>
            <p class="mt-1 text-3xl font-semibold text-gray-900"><%= current_user.admin? ? Adapter.active.count : Adapter.active.where(user: current_user).count %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-500 truncate">Endpoints</p>
            <p class="mt-1 text-3xl font-semibold text-gray-900"><%= Endpoint.count %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-500 truncate">Execution Logs</p>
            <p class="mt-1 text-3xl font-semibold text-gray-900"><%= ExecutionLog.count %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
