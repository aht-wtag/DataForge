<%= form_with(model: [adapter, credential], local: true, class: "space-y-6") do |form| %>
  <% if credential.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <h2 class="text-sm font-medium text-red-800"><%= pluralize(credential.errors.count, "error") %> prohibited this credential from being saved:</h2>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% credential.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-y-8 gap-x-4 sm:grid-cols-6">
    <div class="sm:col-span-3">
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name,
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-3">
      <%= form.label :credential_type, "Type", class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :credential_type, Credential.credential_types.keys.map { |t| [t.humanize, t] }, {},
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-3">
      <%= form.label :auth_header_name, "Header Name", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :auth_header_name, placeholder: "Authorization",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
    </div>

    <div class="sm:col-span-3">
      <%= form.label :value, class: "block text-sm font-medium text-gray-700" %>
      <%= form.password_field :value, placeholder: credential.persisted? ? "(leave blank to keep current)" : "",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
      <% if credential.persisted? %>
        <p class="mt-1 text-xs text-gray-500">Current: <%= credential.masked_value %></p>
      <% end %>
    </div>
  </div>

  <div class="flex justify-end space-x-4 pt-6 mt-6 border-t border-gray-200">
    <%= link_to "Cancel", adapter_credentials_path(adapter),
          class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
    <%= form.submit class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
