<%= form_with(model: adapter, local: true, class: "space-y-6", data: { controller: "adapter-form" }) do |form| %>
  <% if adapter.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <h2 class="text-sm font-medium text-red-800"><%= pluralize(adapter.errors.count, "error") %> prohibited this adapter from being saved:</h2>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% adapter.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-y-8 gap-x-4 sm:grid-cols-6">
    <div class="sm:col-span-4">
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name,
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-4">
      <%= form.label :adapter_type, "Adapter Type", class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :adapter_type, Adapter.adapter_types.keys.map { |t| [t.humanize, t] },
            { prompt: "Select adapter type..." },
            data: { adapter_type_select: "true", action: "change->adapter-form#toggleFields" },
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-4">
      <%= form.label :base_url, class: "block text-sm font-medium text-gray-700" %>
      <%= form.url_field :base_url, placeholder: "https://api.example.com",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
    </div>

    <div class="sm:col-span-6">
      <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, rows: 3,
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :status, Adapter.statuses.keys.map { |s| [s.humanize, s] }, {},
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :rate_limit, "Rate Limit (req/min)", class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :rate_limit, min: 1,
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :timeout, "Timeout (seconds)", class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :timeout, min: 1, max: 300,
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
    </div>
  </div>

  <div data-adapter-form-target="dilocFields" style="display: <%= adapter.diloc? ? 'block' : 'none' %>;">
    <div class="mt-6 pt-6 border-t border-gray-200">
      <h3 class="text-lg font-medium text-gray-900 mb-4">DiLoc Configuration</h3>
      <p class="text-sm text-gray-500 mb-4">These fields are required when the adapter type is DiLoc.</p>

      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="sm:col-span-4">
          <%= form.label "config_DiLocBaseurl", "DiLoc Base URL", class: "block text-sm font-medium text-gray-700" %>
          <span class="text-red-500 text-xs">*</span>
          <%= form.url_field "config[DiLocBaseurl]",
                value: adapter.config["DiLocBaseurl"],
                placeholder: "https://api.diloc.example.com",
                data: { required: "true" },
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
        </div>

        <div class="sm:col-span-4">
          <%= form.label "config_apiKey", "API Key", class: "block text-sm font-medium text-gray-700" %>
          <span class="text-red-500 text-xs">*</span>
          <%= form.password_field "config[apiKey]",
                value: adapter.config["apiKey"],
                data: { required: "true" },
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
        </div>

        <div class="sm:col-span-4">
          <%= form.label "config_oevpadCockpiturl", "OeVPAD Cockpit URL", class: "block text-sm font-medium text-gray-700" %>
          <span class="text-red-500 text-xs">*</span>
          <%= form.url_field "config[oevpadCockpiturl]",
                value: adapter.config["oevpadCockpiturl"],
                placeholder: "https://cockpit.oevpad.example.com",
                data: { required: "true" },
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
        </div>

        <div class="sm:col-span-4">
          <%= form.label "config_CockpitApiKey", "Cockpit API Key", class: "block text-sm font-medium text-gray-700" %>
          <span class="text-red-500 text-xs">*</span>
          <%= form.password_field "config[CockpitApiKey]",
                value: adapter.config["CockpitApiKey"],
                data: { required: "true" },
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
        </div>

        <div class="sm:col-span-3">
          <%= form.label "config_startDateTime", "Start Date/Time (optional override)", class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_field "config[startDateTime]",
                value: adapter.config["startDateTime"],
                placeholder: "2026-01-01T00:00:00",
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
        </div>

        <div class="sm:col-span-3">
          <%= form.label "config_endDateTime", "End Date/Time (optional override)", class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_field "config[endDateTime]",
                value: adapter.config["endDateTime"],
                placeholder: "2026-01-06T00:00:00",
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2 font-mono" %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label "config_offsetHours", "Offset Hours", class: "block text-sm font-medium text-gray-700" %>
          <%= form.number_field "config[offsetHours]",
                value: adapter.config["offsetHours"],
                placeholder: "24",
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm border px-3 py-2" %>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-end space-x-4 pt-6 mt-6 border-t border-gray-200">
    <%= link_to "Cancel", adapter.persisted? ? adapter_path(adapter) : adapters_path,
          class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
    <%= form.submit class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
