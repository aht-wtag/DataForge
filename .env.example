# --- Application ---
RAILS_ENV=development
APP_PORT=3000

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_INTERNAL_PORT=5432
POSTGRES_DB=dataforge_development
POSTGRES_USER=dataforge
POSTGRES_PASSWORD=changeme

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Rails ---
RAILS_MASTER_KEY=replace_with_actual_master_key
SECRET_KEY_BASE=replace_with_actual_secret_key_base

# --- Sidekiq ---
SIDEKIQ_CONCURRENCY=5

# --- Active Storage (local) ---
ACTIVE_STORAGE_SERVICE=local

# --- Mailer (Mailpit for dev) ---
MAILPIT_HOST=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
MAILER_SENDER=noreply@dataforge.local

# --- Webhooks ---
WEBHOOK_HMAC_SECRET=changeme_hmac_secret
